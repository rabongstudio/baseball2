  },
  {
    "schema_name": "public",
    "function_name": "baseball_is_school_admin",
    "arguments": "",
    "return_type": "boolean",
    "language": "sql",
    "source_code": "\r\n  SELECT EXISTS (\r\n    SELECT 1\r\n    FROM public.baseball_profiles\r\n    WHERE id = auth.uid()\r\n      AND role = 'admin'\r\n  )\r\n"
  },
  {
    "schema_name": "public",
    "function_name": "baseball_owns_player",
    "arguments": "p_player_id bigint",
    "return_type": "boolean",
    "language": "sql",
    "source_code": "\r\n  select exists (\r\n    select 1\r\n    from public.baseball_players p\r\n    where p.id = p_player_id\r\n      and p.owner_user_id = auth.uid()\r\n  )\r\n"
  },
  {
    "schema_name": "public",
    "function_name": "baseball_admin_update_role",
    "arguments": "p_user_id uuid, p_role text",
    "return_type": "baseball_profiles",
    "language": "plpgsql",
    "source_code": "\r\nDECLARE\r\n  v_my_school bigint;\r\n  v_target public.baseball_profiles;\r\n  v_result public.baseball_profiles;\r\nBEGIN\r\n  v_my_school := public.baseball_my_school_id();\r\n\r\n  IF NOT public.baseball_is_school_admin() THEN\r\n    RAISE EXCEPTION '관리자만 변경할 수 있습니다.';\r\n  END IF;\r\n\r\n  IF p_role NOT IN ('admin', 'member', 'recorder') THEN\r\n    RAISE EXCEPTION '허용되지 않은 권한입니다.';\r\n  END IF;\r\n\r\n  SELECT *\r\n    INTO v_target\r\n  FROM public.baseball_profiles\r\n  WHERE id = p_user_id\r\n    AND school_id = v_my_school;\r\n\r\n  IF NOT FOUND THEN\r\n    RAISE EXCEPTION '같은 학교 사용자만 변경할 수 있습니다.';\r\n  END IF;\r\n\r\n  -- admin은 오직 1명만 허용\r\n  IF p_role = 'admin' THEN\r\n    -- 같은 학교의 기존 admin을 모두 member로 변경 (대상자 제외)\r\n    UPDATE public.baseball_profiles\r\n    SET role = 'member'\r\n    WHERE school_id = v_my_school\r\n      AND role = 'admin'\r\n      AND id <> p_user_id;\r\n  END IF;\r\n\r\n  UPDATE public.baseball_profiles\r\n  SET role = p_role\r\n  WHERE id = p_user_id\r\n    AND school_id = v_my_school\r\n  RETURNING * INTO v_result;\r\n\r\n  RETURN v_result;\r\nEND;\r\n"
  },
  {
    "schema_name": "public",
    "function_name": "baseball_my_school_id",
    "arguments": "",
    "return_type": "bigint",
    "language": "plpgsql",
    "source_code": "\r\nDECLARE\r\n  v_school_id bigint;\r\nBEGIN\r\n  SELECT school_id INTO v_school_id\r\n  FROM public.baseball_profiles\r\n  WHERE id = auth.uid()\r\n  LIMIT 1;\r\n  RETURN v_school_id;\r\nEND;\r\n"
  }
]
