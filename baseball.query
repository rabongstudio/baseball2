[
  {
    "schemaname": "public",
    "tablename": "baseball_game_player_records",
    "policyname": "baseball_records_delete_admin_or_owner",
    "permissive": "PERMISSIVE",
    "roles": "{public}",
    "action": "DELETE",
    "using_expression": "(EXISTS ( SELECT 1\n   FROM (baseball_games g\n     JOIN baseball_players p ON ((p.id = baseball_game_player_records.player_id)))\n  WHERE ((g.id = baseball_game_player_records.game_id) AND (g.school_id = baseball_my_school_id()) AND (p.school_id = baseball_my_school_id()) AND (baseball_is_school_admin() OR (p.owner_user_id = auth.uid())))))",
    "check_expression": null
  },
  {
    "schemaname": "public",
    "tablename": "baseball_game_player_records",
    "policyname": "baseball_records_insert_admin_or_owner",
    "permissive": "PERMISSIVE",
    "roles": "{public}",
    "action": "INSERT",
    "using_expression": null,
    "check_expression": "(EXISTS ( SELECT 1\n   FROM (baseball_games g\n     JOIN baseball_players p ON ((p.id = baseball_game_player_records.player_id)))\n  WHERE ((g.id = baseball_game_player_records.game_id) AND (g.school_id = baseball_my_school_id()) AND (p.school_id = baseball_my_school_id()) AND (baseball_is_school_admin() OR (p.owner_user_id = auth.uid())))))"
  },
  {
    "schemaname": "public",
    "tablename": "baseball_game_player_records",
    "policyname": "baseball_records_select_school_or_my_player_records",
    "permissive": "PERMISSIVE",
    "roles": "{public}",
    "action": "SELECT",
    "using_expression": "((EXISTS ( SELECT 1\n   FROM baseball_games g\n  WHERE ((g.id = baseball_game_player_records.game_id) AND (g.school_id = baseball_my_school_id())))) OR (EXISTS ( SELECT 1\n   FROM baseball_players p\n  WHERE ((p.id = baseball_game_player_records.player_id) AND (p.owner_user_id = auth.uid())))))",
    "check_expression": null
  },
  {
    "schemaname": "public",
    "tablename": "baseball_game_player_records",
    "policyname": "baseball_records_update_admin_or_owner",
    "permissive": "PERMISSIVE",
    "roles": "{public}",
    "action": "UPDATE",
    "using_expression": "(EXISTS ( SELECT 1\n   FROM (baseball_games g\n     JOIN baseball_players p ON ((p.id = baseball_game_player_records.player_id)))\n  WHERE ((g.id = baseball_game_player_records.game_id) AND (g.school_id = baseball_my_school_id()) AND (p.school_id = baseball_my_school_id()) AND (baseball_is_school_admin() OR (p.owner_user_id = auth.uid())))))",
    "check_expression": "(EXISTS ( SELECT 1\n   FROM (baseball_games g\n     JOIN baseball_players p ON ((p.id = baseball_game_player_records.player_id)))\n  WHERE ((g.id = baseball_game_player_records.game_id) AND (g.school_id = baseball_my_school_id()) AND (p.school_id = baseball_my_school_id()) AND (baseball_is_school_admin() OR (p.owner_user_id = auth.uid())))))"
