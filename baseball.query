    "language": "plpgsql",
    "source_code": "\r\nBEGIN\r\n  NEW.updated_at = now();\r\n  RETURN NEW;\r\nEND;\r\n"
  },
  {
    "schema_name": "public",
    "function_name": "baseball_set_updated_at",
